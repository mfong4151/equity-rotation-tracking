# --- Postgres ---
# SQLAlchemy 2 + psycopg3 driver scheme. Use a DB distinct from other projects.
DATABASE_URL=postgresql+psycopg://mfong415:dev123@localhost:5432/equity_rotation

# --- Polygon ---
POLYGON_API_KEY=replace-me

# --- Collector behavior ---
# Timeframe stored in stock_data. For MVP we only do daily.
COLLECTOR_TIMEFRAME=1d
# How far back to backfill when a ticker has no rows yet (days).
COLLECTOR_INITIAL_BACKFILL_DAYS=400

# --- Cleanup behavior ---
# Rolling window per the MVP spec.
CLEANUP_RETENTION_DAYS=365
